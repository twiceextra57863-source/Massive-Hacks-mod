{
  "schemaVersion": 1,
  "id": "skincustomizer",
  "version": "${version}",
  "name": "Skin Dashboard",
  "description": "Client-side skin dashboard for Minecraft 1.21.4 - Pure Code GUI",
  "authors": ["MineTwice"],
  "contact": {
    "sources": "https://github.com/yourname/skincustomizer"
  },
  "license": "MIT",
  "icon": "assets/skincustomizer/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.yourname.skincustomizer.SkinDashboardMod"
    ]
  },
  "mixins": [
    "mixins.skincustomizer.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.4",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
