{
    "schemaVersion": 1,
    "id": "skinchanger",
    "version": "1.0.0",
    "name": "Skin Changer Mod",
    "description": "Change your Minecraft skin directly from main menu",
    "authors": ["Twicefear"],
    "contact": {
        "homepage": "https://github.com/tumhara/skin-changer"
    },
    "license": "MIT",
    "icon": "assets/skinchanger/icon.png",
    "environment": "client",
    "entrypoints": {
        "main": [
            "com.tumhara.mod.SkinChangerMod"
        ],
        "client": [
            "com.tumhara.mod.SkinChangerModClient"
        ]
    },
    "mixins": [
        "tumharomod.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.16.9",
        "minecraft": ">=1.21.4",
        "java": ">=21",
        "fabric-api": "*"
    },
    "custom": {
        "modmenu:clientsideOnly": true
    }
}
